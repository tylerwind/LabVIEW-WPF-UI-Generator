    <!-- ============================================================ -->
    <!-- 2. 统一拟态容器模板 (Neumorphic Icon Container) -->
    <!-- ============================================================ -->
    
    <Style x:Key="NeuIconCore" TargetType="ContentControl">
        <Setter Property="Width" Value="24"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Grid>
                        <!-- 拟态底座阴影 -->
                        <Border Background="#F0F0F3" CornerRadius="6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="4" ShadowDepth="1.5" Direction="315" Color="#AEAEC0" Opacity="0.5"/>
                            </Border.Effect>
                        </Border>
                        
                        <!-- 玻璃半透明背景 (使用 Foreground 颜色并降低透明度) -->
                        <Rectangle Margin="4" Fill="{TemplateBinding Foreground}" RadiusX="3" RadiusY="3" Opacity="0.15">
                            <Rectangle.Effect>
                                <BlurEffect Radius="3"/>
                            </Rectangle.Effect>
                        </Rectangle>

                        <!-- 图标路径层 -->
                        <Viewbox Margin="5">
                            <Path Data="{TemplateBinding Content}" Fill="{TemplateBinding Foreground}" Stretch="Uniform"/>
                        </Viewbox>
                        
                        <!-- 亮边高光 -->
                        <Border BorderBrush="White" BorderThickness="0.8,0.8,0,0" CornerRadius="6" Opacity="0.8"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
