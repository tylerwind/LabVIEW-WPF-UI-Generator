<Window x:Class="ControlDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF 控件生成器 v2.0" Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F3">

    <Window.Resources>
        <!-- 全局字体 -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#444444"/>
        </Style>

        <!-- 分组标题 -->
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#666677"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <!-- 标签 -->
        <Style x:Key="PropLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#666677"/>
            <Setter Property="Margin" Value="0,4,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 滑动条 -->
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 文本框 (编辑器) -->
        <Style x:Key="PropTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D1D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 按钮 -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 预设主题按钮 -->
        <Style x:Key="PresetBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E0E0E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F5F5F8"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#D1D1D1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 侧边栏导航按钮样式 -->
        <Style x:Key="NavTab" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent" Padding="0,16" Cursor="Hand"
                                BorderBrush="#4A90E2" BorderThickness="0,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6" Foreground="#888899"/>
                                <TextBlock x:Name="txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#888899" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E8E8EE"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#333333"/>
                                <Setter TargetName="txt" Property="Foreground" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="bg" Property="BorderThickness" Value="4,0,0,0"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#4A90E2"/>
                                <Setter TargetName="txt" Property="Foreground" Value="#4A90E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80"/> <!-- 极左侧边栏导航 -->
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 极左：导航侧边栏 ========== -->
        <Border Grid.Column="0" Background="#F5F5F8" BorderBrush="#E0E0E6" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,16,0,0">
                <RadioButton x:Name="TabTextInput" Tag="📝" Content="文本框" Style="{StaticResource NavTab}" IsChecked="True" Checked="Navigation_Checked"/>
                <RadioButton x:Name="TabNumeric" Tag="🔢" Content="数值框" Style="{StaticResource NavTab}" Checked="Navigation_Checked"/>
                <RadioButton x:Name="TabComboBox" Tag="🔽" Content="下拉框" Style="{StaticResource NavTab}" Checked="Navigation_Checked"/>
                <RadioButton x:Name="TabSlider" Tag="🎚️" Content="滑动杆" Style="{StaticResource NavTab}" Checked="Navigation_Checked"/>
                <RadioButton x:Name="TabButton" Tag="🔘" Content="按钮" Style="{StaticResource NavTab}" Checked="Navigation_Checked"/>
                <RadioButton x:Name="TabLed" Tag="💡" Content="指示灯" Style="{StaticResource NavTab}" Checked="Navigation_Checked"/>
                <RadioButton x:Name="TabToggle" Tag="🔀" Content="开关" Style="{StaticResource NavTab}" Checked="Navigation_Checked"/>
                <RadioButton x:Name="TabProgress" Tag="📊" Content="进度条" Style="{StaticResource NavTab}" Checked="Navigation_Checked"/>
            </StackPanel>
        </Border>

        <!-- ========== 左侧：样式编辑器 ========== -->
        <Border Grid.Column="1" Background="#FAFAFA" BorderBrush="#E0E0E6" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 顶部标题 -->
                <Border DockPanel.Dock="Top" Padding="16,12" Background="#E8E8EE" BorderBrush="#E0E0E6" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="🎨 样式编辑器" FontSize="16" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                        <Button x:Name="BtnImport" Content="📂 导入配置" HorizontalAlignment="Right" VerticalAlignment="Center" 
                                Padding="8,4" Background="#FFFFFF" Foreground="#555555" BorderBrush="#D1D1D1" Cursor="Hand"
                                Click="BtnImport_Click" ToolTip="导入之前导出的 .style.json 配置文件"/>
                    </Grid>
                </Border>

                <!-- 底部导出 -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,8">
                    <TextBlock Text="控件名称" Style="{StaticResource GroupTitle}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtControlName" Style="{StaticResource PropTextBox}"
                             Text="MyTextInput" FontSize="13" Padding="8,5"
                             ToolTip="每个名称生成独立的 DLL，可在 LabVIEW 中同时使用"/>
                    <TextBlock Text="ℹ 不同名称 = 独立 DLL，可同时使用" FontSize="10" Foreground="#888899" Margin="0,2,0,6"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnExport" Content="📦 导出单个" Style="{StaticResource ActionBtn}"
                                Background="#38A169" Foreground="White" BorderBrush="#2F855A"
                                Grid.Column="0" Click="BtnExport_Click" ToolTip="仅导出当前预览选中的独立控件"/>
                        <Button x:Name="BtnExportAll" Content="🎁 导出合集" Style="{StaticResource ActionBtn}"
                                Background="#4A90E2" Foreground="White" BorderBrush="#357ABD"
                                Grid.Column="2" Click="BtnExportAll_Click" ToolTip="将全部8种控件打包进一个 DLL"/>
                    </Grid>
                    <TextBlock x:Name="TxtStatus" Text="" FontSize="11" Foreground="#28A745"
                               HorizontalAlignment="Center" Margin="0,4" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- 滚动区域 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,0,14,0">
                    <StackPanel>

                        <!-- 预设主题 -->
                        <TextBlock Text="预设主题" Style="{StaticResource GroupTitle}"/>
                        <StackPanel x:Name="PresetPanel"/>

                        <!-- 背景 -->
                        <StackPanel x:Name="GroupBackground">
                        <TextBlock Text="背景" Style="{StaticResource GroupTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="底色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchControlBg" Grid.Row="0" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtControlBg" Grid.Row="0" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="1" Text="渐变起" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchGradStart" Grid.Row="1" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtGradStart" Grid.Row="1" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="2" Text="渐变中" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchGradMid" Grid.Row="2" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtGradMid" Grid.Row="2" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="3" Text="渐变止" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchGradEnd" Grid.Row="3" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtGradEnd" Grid.Row="3" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                        </Grid>
                        </StackPanel>

                        <!-- 边框 -->
                        <StackPanel x:Name="GroupBorder">
                        <TextBlock Text="边框" Style="{StaticResource GroupTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="颜色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchBorderColor" Grid.Row="0" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtBorderColor" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="1" Text="粗细" Style="{StaticResource PropLabel}"/>
                            <Slider x:Name="SliderBorderW" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="4" Value="1" TickFrequency="0.5" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                            <TextBlock x:Name="LblBorderW" Grid.Row="1" Grid.Column="3" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="2" Text="圆角" Style="{StaticResource PropLabel}"/>
                            <Slider x:Name="SliderCorner" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="30" Value="12" ValueChanged="OnSliderChanged"/>
                            <TextBlock x:Name="LblCorner" Grid.Row="2" Grid.Column="3" Style="{StaticResource PropLabel}"/>
                        </Grid>
                        </StackPanel>

                        <!-- 阴影 -->
                        <StackPanel x:Name="GroupShadow">
                        <TextBlock Text="阴影" Style="{StaticResource GroupTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="颜色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchShadowColor" Grid.Row="0" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtShadowColor" Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="1" Text="模糊" Style="{StaticResource PropLabel}"/>
                            <Slider x:Name="SliderShadowBlur" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="30" Value="10" ValueChanged="OnSliderChanged"/>
                            <TextBlock x:Name="LblShadowBlur" Grid.Row="1" Grid.Column="3" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="2" Text="偏移" Style="{StaticResource PropLabel}"/>
                            <Slider x:Name="SliderShadowDepth" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="15" Value="4" ValueChanged="OnSliderChanged"/>
                            <TextBlock x:Name="LblShadowDepth" Grid.Row="2" Grid.Column="3" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="3" Text="透明" Style="{StaticResource PropLabel}"/>
                            <Slider x:Name="SliderShadowOp" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="1" Value="0.5" ValueChanged="OnSliderChanged"/>
                            <TextBlock x:Name="LblShadowOp" Grid.Row="3" Grid.Column="3" Style="{StaticResource PropLabel}"/>
                        </Grid>
                        </StackPanel>

                        <!-- 字体 -->
                        <StackPanel x:Name="GroupFont">
                        <TextBlock Text="字体" Style="{StaticResource GroupTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/><ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="字族" Style="{StaticResource PropLabel}"/>
                            <TextBox x:Name="TxtFontFamily" Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="1" Text="字号" Style="{StaticResource PropLabel}"/>
                            <Slider x:Name="SliderFontSize" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Minimum="10" Maximum="24" Value="14" ValueChanged="OnSliderChanged"/>
                            <TextBlock x:Name="LblFontSize" Grid.Row="1" Grid.Column="3" Style="{StaticResource PropLabel}"/>
                            <TextBlock Grid.Row="2" Text="字色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchFontColor" Grid.Row="2" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtFontColor" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="3" Text="标签色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchLabelColor" Grid.Row="3" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtLabelColor" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="4" Text="标签号" Style="{StaticResource PropLabel}"/>
                            <Slider x:Name="SliderLabelSize" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Minimum="9" Maximum="16" Value="11" ValueChanged="OnSliderChanged"/>
                            <TextBlock x:Name="LblLabelSize" Grid.Row="4" Grid.Column="3" Style="{StaticResource PropLabel}"/>
                        </Grid>
                        </StackPanel>

                        <!-- 聚焦 -->
                        <StackPanel x:Name="GroupFocus">
                        <TextBlock Text="聚焦效果" Style="{StaticResource GroupTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="边框色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchFocusBorder" Grid.Row="0" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtFocusBorder" Grid.Row="0" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="1" Text="强调色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchAccentColor" Grid.Row="1" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtAccentColor" Grid.Row="1" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                        </Grid>
                        </StackPanel>

                        <!-- LED 颜色 (仅指示灯) -->
                        <StackPanel x:Name="GroupLedColors" Visibility="Collapsed">
                        <TextBlock Text="LED 颜色" Style="{StaticResource GroupTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="亮灯色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchLedOn" Grid.Row="0" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtLedOnColor" Grid.Row="0" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="1" Text="灭灯色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchLedOff" Grid.Row="1" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtLedOffColor" Grid.Row="1" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                        </Grid>
                        </StackPanel>

                        <Border Height="20"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ========== 右侧：实时预览 ========== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 预览标题栏 -->
            <Border Grid.Row="0" Padding="20,12" Background="#E8E8EE" BorderBrush="#E0E0E6" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock Text="👁 实时预览" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                    <TextBlock DockPanel.Dock="Right" Text="在此输入文字测试效果 ↓" FontSize="11"
                               Foreground="#888899" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- 预览区域 -->
            <Border Grid.Row="1" x:Name="PreviewContainer" Padding="40" Background="#F0F0F3">
                <!-- 动态渲染预览控件 -->
            </Border>
        </Grid>
    </Grid>
</Window>
