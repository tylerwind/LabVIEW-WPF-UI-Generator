<Window x:Class="ControlDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF 控件生成器 v3.2" Width="1200" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F3">

    <Window.Resources>
        <!-- 全局字体 -->
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#444444"/>
        </Style>

        <!-- 分组标题 -->
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#666677"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>

        <!-- 标签 -->
        <Style x:Key="PropLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#666677"/>
            <Setter Property="Margin" Value="0,4,8,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 滑动条 -->
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 文本框 (编辑器) -->
        <Style x:Key="PropTextBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D1D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PropComboBox" TargetType="ComboBox">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D1D1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 按钮 -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="8" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 预设主题按钮 -->
        <Style x:Key="PresetBtn" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#555555"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E0E0E6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" CornerRadius="6" Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F5F5F8"/>
                                <Setter TargetName="bg" Property="BorderBrush" Value="#D1D1D1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 侧边栏导航按钮样式 -->
        <Style x:Key="NavTab" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bg" Background="Transparent" Padding="0,16" Cursor="Hand"
                                BorderBrush="#4A90E2" BorderThickness="0,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontSize="24" HorizontalAlignment="Center" Margin="0,0,0,6" Foreground="#888899"/>
                                <TextBlock x:Name="txt" Text="{TemplateBinding Content}" FontSize="12" Foreground="#888899" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#E8E8EE"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#333333"/>
                                <Setter TargetName="txt" Property="Foreground" Value="#333333"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#FFFFFF"/>
                                <Setter TargetName="bg" Property="BorderThickness" Value="4,0,0,0"/>
                                <Setter TargetName="icon" Property="Foreground" Value="#4A90E2"/>
                                <Setter TargetName="txt" Property="Foreground" Value="#4A90E2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- ===== 拟态一级导航按钮 ===== -->
        <Style x:Key="NeumorphicNavBtn" TargetType="RadioButton">
            <Setter Property="Margin" Value="6,8,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <!-- 去掉 ClipToBounds，容器背景透明 -->
                        <Grid x:Name="tplGrid" Height="48" Background="Transparent" HorizontalAlignment="Stretch">
                            <!-- 凸起态：高光 -->
                            <Border x:Name="lightBorder" CornerRadius="14" Margin="3">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="16" Direction="135" ShadowDepth="4" Color="#FFFFFF" Opacity="1.0"/>
                                </Border.Effect>
                            </Border>
                            <!-- 凸起态：阴影 -->
                            <Border x:Name="darkBorder" CornerRadius="14" Background="#F0F0F3" Margin="3">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="18" Direction="315" ShadowDepth="5" Color="#AEAEC0" Opacity="0.5"/>
                                </Border.Effect>
                                <Grid x:Name="contentGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="col0" Width="60"/>
                                        <ColumnDefinition x:Name="col1" Width="*"/>
                                        <ColumnDefinition x:Name="col2" Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- 图标区域：矢量拟态版 -->
                                    <Grid Grid.Column="0" x:Name="iconHost" HorizontalAlignment="Center">
                                        <ContentControl x:Name="icon" Style="{StaticResource NeuIconCore}" 
                                                        Content="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                                        Width="28" Height="28" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>

                                    <TextBlock x:Name="txt" Grid.Column="1" Text="{TemplateBinding Content}" FontSize="13" FontWeight="SemiBold" Foreground="#666677" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="arrow" Grid.Column="2" Text="▶" FontSize="8" Foreground="#BBBBCC" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                </Grid>
                            </Border>

                            <!-- 用户要求不再使用陷入态，故删除 pressedBorder -->
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txt" Property="Foreground" Value="#333344"/>
                                <Setter TargetName="icon" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <!-- 激活态：不再切换为压下态，而是加强图标亮度并改变文字颜色 -->
                                <Setter TargetName="txt" Property="Foreground" Value="#4A90E2"/>
                                <Setter TargetName="txt" Property="FontWeight" Value="Bold"/>
                                <Setter TargetName="arrow" Property="Text" Value="▼"/>
                                <Setter TargetName="arrow" Property="Foreground" Value="#4A90E2"/>
                                <Setter TargetName="darkBorder" Property="BorderBrush" Value="#D1D1D6"/>
                                <Setter TargetName="darkBorder" Property="BorderThickness" Value="0.5"/>
                            </Trigger>
                            <!-- 自动适配收缩状态 -->
                            <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <Setter TargetName="txt" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="arrow" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="col0" Property="Width" Value="*"/>
                                <Setter TargetName="col1" Property="Width" Value="0"/>
                                <Setter TargetName="col2" Property="Width" Value="0"/>
                                <!-- 针对收缩态的阴影余量优化 -->
                                <Setter TargetName="tplGrid" Property="Margin" Value="4,0"/>
                                <Setter TargetName="darkBorder" Property="Margin" Value="5"/>
                                <Setter TargetName="lightBorder" Property="Margin" Value="5"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== 拟态二级子项按钮 ===== -->
        <Style x:Key="NeumorphicSubBtn" TargetType="RadioButton">
            <Setter Property="Margin" Value="24,6,6,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="subTplGrid" Height="38" Background="Transparent" Margin="6,0">
                            <!-- 凸起态 -->
                            <Border x:Name="subLight" CornerRadius="12" Margin="2">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" Direction="135" ShadowDepth="3" Color="#FFFFFF" Opacity="0.9"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="subDark" CornerRadius="12" Background="#F0F0F3" Margin="2">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="14" Direction="315" ShadowDepth="4" Color="#AEAEC0" Opacity="0.45"/>
                                </Border.Effect>
                                <Grid x:Name="subContentGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="subCol0" Width="40"/>
                                        <ColumnDefinition x:Name="subCol1" Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Grid Grid.Column="0" x:Name="subIconHost" HorizontalAlignment="Center">
                                        <ContentControl Style="{StaticResource NeuIconCore}" 
                                                        Content="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                                        Width="22" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock x:Name="subTxt" Grid.Column="1" Text="{TemplateBinding Content}" FontSize="12" Foreground="#777788" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                            </Border>

                            <!-- 陷入态 -->
                            <Border x:Name="subPressed" CornerRadius="12" Margin="3" Background="#E6E6E9" BorderBrush="#D1D1D6" BorderThickness="1" Visibility="Collapsed">
                                <Grid x:Name="subPressedGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition x:Name="subPCol0" Width="40"/>
                                        <ColumnDefinition x:Name="subPCol1" Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0" HorizontalAlignment="Center">
                                        <ContentControl Style="{StaticResource NeuIconCore}" 
                                                        Content="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"
                                                        Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"
                                                        Width="22" Height="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Grid>
                                    <TextBlock x:Name="subPTxt" Grid.Column="1" Text="{TemplateBinding Content}" FontSize="12" Foreground="#4A90E2" FontWeight="Bold" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="subTxt" Property="Foreground" Value="#4A90E2"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="subLight" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="subDark" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="subPressed" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <!-- 二级按钮适配收缩态 -->
                            <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                <!-- 移除缩进 -->
                                <Setter Property="Margin" Value="6,6,6,0"/>
                                <Setter TargetName="subTxt" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="subPTxt" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="subCol0" Property="Width" Value="*"/>
                                <Setter TargetName="subCol1" Property="Width" Value="0"/>
                                <Setter TargetName="subPCol0" Property="Width" Value="*"/>
                                <Setter TargetName="subPCol1" Property="Width" Value="0"/>
                                <!-- 针对收缩态的阴影余量和模糊优化 -->
                                <Setter TargetName="subDark" Property="Margin" Value="5"/>
                                <Setter TargetName="subLight" Property="Margin" Value="5"/>
                                <Setter TargetName="subPressed" Property="Margin" Value="6"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="240"/> <!-- 拟态侧边栏 -->
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 拟态导航侧边栏 ========== -->
        <Border Grid.Column="0" Background="#F0F0F3">
            <Grid>
                <!-- 收缩拨片 -->
                <Button x:Name="BtnSidebarToggle" Content="❮" Click="BtnSidebarToggle_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,0,0"
                        Width="24" Height="24" FontSize="10" Cursor="Hand"
                        Background="#F0F0F3" BorderBrush="Transparent"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              BorderThickness="0" Background="Transparent" Margin="0,40,0,0"
                              Padding="4">
                    <StackPanel>
                        <!-- ===== 字符串分组 ===== -->
                        <RadioButton x:Name="NavGrpString" Tag="{StaticResource Geo_String}" Content="字符串" Foreground="#2196F3"
                                     Style="{StaticResource NeumorphicNavBtn}" Click="NavGroup_Click"/>
                        <RadioButton x:Name="TabTextInput" Tag="{StaticResource Geo_Pencil}" Content="文本框" Foreground="#2196F3"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" IsChecked="True" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabComboBox" Tag="{StaticResource Geo_List}" Content="下拉框" Foreground="#2196F3"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>

                        <!-- ===== 数值分组 ===== -->
                        <RadioButton x:Name="NavGrpNumeric" Tag="{StaticResource Geo_Numeric}" Content="数值" Foreground="#4CAF50"
                                     Style="{StaticResource NeumorphicNavBtn}" Click="NavGroup_Click"/>
                        <RadioButton x:Name="TabNumeric" Tag="{StaticResource Geo_Calculator}" Content="数值框" Foreground="#4CAF50"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabSlider" Tag="{StaticResource Geo_Slider}" Content="滑动杆" Foreground="#4CAF50"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabProgress" Tag="{StaticResource Geo_Progress}" Content="进度条" Foreground="#4CAF50"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>

                        <!-- ===== 布尔分组 ===== -->
                        <RadioButton x:Name="NavGrpBool" Tag="{StaticResource Geo_Boolean}" Content="布尔" Foreground="#FF9800"
                                     Style="{StaticResource NeumorphicNavBtn}" Click="NavGroup_Click"/>
                        <RadioButton x:Name="TabButton" Tag="{StaticResource Geo_Button}" Content="普通按钮" Foreground="#FF9800"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabIconButton" Tag="{StaticResource Geo_Button}" Content="图标按钮" Foreground="#FF9800"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabLed" Tag="{StaticResource Geo_Led}" Content="指示灯" Foreground="#FF9800"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabToggle" Tag="{StaticResource Geo_Toggle}" Content="开关" Foreground="#FF9800"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>

                        <!-- ===== 图表分组 ===== -->
                        <RadioButton x:Name="NavGrpChart" Tag="{StaticResource Geo_Chart}" Content="图表" Foreground="#9C27B0"
                                     Style="{StaticResource NeumorphicNavBtn}" Click="NavGroup_Click"/>
                        <RadioButton x:Name="TabChart" Tag="{StaticResource Geo_Wave}" Content="折线图" Foreground="#9C27B0"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabPie" Tag="{StaticResource Geo_Pie}" Content="饼图" Foreground="#9C27B0"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabGauge" Tag="{StaticResource Geo_Gauge}" Content="仪表" Foreground="#9C27B0"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabTable" Tag="{StaticResource Geo_Table}" Content="数据表" Foreground="#9C27B0"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabTree" Tag="{StaticResource Geo_Tree}" Content="树形" Foreground="#9C27B0"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Checked="Navigation_Checked"/>

                        <Separator Margin="6,16,6,8" Background="#E0E0E6"/>

                        <!-- ===== 容器布局 ===== -->
                        <RadioButton x:Name="NavGrpLayout" Tag="{StaticResource Geo_Sidebar}" Content="容器布局" Foreground="#E91E63"
                                     Style="{StaticResource NeumorphicNavBtn}" Click="NavGroup_Click"/>
                        <RadioButton x:Name="TabSidebar" Tag="{StaticResource Geo_Sidebar}" Content="侧边栏" Foreground="#E91E63"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Visibility="Collapsed" Checked="Navigation_Checked"/>
                        <RadioButton x:Name="TabTopbar" Tag="{StaticResource Geo_Topbar}" Content="顶边栏" Foreground="#E91E63"
                                     Style="{StaticResource NeumorphicSubBtn}" GroupName="NavMain" Visibility="Collapsed" Checked="Navigation_Checked"/>

                        <Separator Margin="6,16,6,8" Background="#E0E0E6"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ========== 左侧：样式编辑器 ========== -->
        <Border Grid.Column="1" Background="#FAFAFA" BorderBrush="#E0E0E6" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 顶部标题 -->
                <Border DockPanel.Dock="Top" Padding="16,12" Background="#E8E8EE" BorderBrush="#E0E0E6" BorderThickness="0,0,0,1">
                    <Grid>
                        <TextBlock Text="🎨 样式编辑器" FontSize="16" FontWeight="Bold" Foreground="#333333" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="BtnImport" Content="📂 导入配置" Padding="8,4" Background="#FFFFFF" Foreground="#555555" BorderBrush="#D1D1D1" Cursor="Hand" Click="BtnImport_Click" ToolTip="导入之前导出的 .style.json 配置文件"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 底部导出 -->
                <StackPanel DockPanel.Dock="Bottom" Margin="12,8">
                    <TextBlock Text="控件名称" Style="{StaticResource GroupTitle}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtControlName" Style="{StaticResource PropTextBox}"
                             Text="MyTextInput" FontSize="13" Padding="8,5"
                             ToolTip="每个名称生成独立的 DLL，可在 LabVIEW 中同时使用"/>
                    <TextBlock Text="ℹ 不同名称 = 独立 DLL，可同时使用" FontSize="10" Foreground="#888899" Margin="0,2,0,6"/>
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="BtnExport" Content="📦 导出单个" Style="{StaticResource ActionBtn}"
                                Background="#38A169" Foreground="White" BorderBrush="#2F855A"
                                Grid.Column="0" Click="BtnExport_Click" ToolTip="仅导出当前预览选中的独立控件"/>
                        <Button x:Name="BtnExportAll" Content="🎁 导出合集" Style="{StaticResource ActionBtn}"
                                Background="#4A90E2" Foreground="White" BorderBrush="#357ABD"
                                Grid.Column="2" Click="BtnExportAll_Click" ToolTip="将全部8种控件打包进一个 DLL"/>
                    </Grid>
                    <TextBlock x:Name="TxtStatus" Text="" FontSize="11" Foreground="#28A745"
                               HorizontalAlignment="Center" Margin="0,4" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- 滚动区域 -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14,0,14,0">
                    <StackPanel>

                        <!-- 预设主题 -->
                        <TextBlock Text="预设主题" Style="{StaticResource GroupTitle}"/>
                        <StackPanel x:Name="PresetPanel"/>

                        <!-- 背景 -->
                        <StackPanel x:Name="GroupBackground">
                        <TextBlock Text="背景" Style="{StaticResource GroupTitle}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/><ColumnDefinition Width="24"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="底色" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchControlBg" Grid.Row="0" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtControlBg" Grid.Row="0" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="1" Text="渐变起" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchGradStart" Grid.Row="1" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtGradStart" Grid.Row="1" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="2" Text="渐变中" Style="{StaticResource PropLabel}"/>
                            <Border x:Name="SwatchGradMid" Grid.Row="2" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtGradMid" Grid.Row="2" Grid.Column="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>
                            <TextBlock Grid.Row="3" Text="渐变止" Style="{StaticResource PropLabel}"/>
