                            <Border x:Name="SwatchTableBg" Grid.Row="3" Grid.Column="1" Width="18" Height="18" CornerRadius="3" BorderBrush="#555" BorderThickness="1" Margin="0,2" Cursor="Hand" MouseLeftButtonDown="Swatch_Click"/>
                            <TextBox x:Name="TxtTableBg" Grid.Row="3" Grid.Column="2" Grid.ColumnSpan="2" Style="{StaticResource PropTextBox}" TextChanged="OnStyleChanged"/>

                            <TextBlock Grid.Row="4" Text="交替色" Style="{StaticResource PropLabel}"/>
                            <Slider x:Name="SliderTableAlt" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" Minimum="0" Maximum="0.2" Value="0.04" TickFrequency="0.01" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                            <TextBlock x:Name="LblTableAlt" Grid.Row="4" Grid.Column="3" Style="{StaticResource PropLabel}"/>

                            <TextBlock Grid.Row="5" Text="网格线" Style="{StaticResource PropLabel}"/>
                            <CheckBox x:Name="ChkTableGridLines" Grid.Row="5" Grid.Column="1" VerticalAlignment="Center" Click="OnGenericStyleChanged"/>

                            <TextBlock Grid.Row="6" Text="显示表头" Style="{StaticResource PropLabel}"/>
                            <CheckBox x:Name="ChkTableHeader" Grid.Row="6" Grid.Column="1" VerticalAlignment="Center" IsChecked="True" Click="OnGenericStyleChanged"/>
                        </Grid>
                        </StackPanel>

                        <!-- 侧边栏配置 (仅侧边栏) -->
                        <StackPanel x:Name="GroupSidebarConfig" Visibility="Collapsed">
                            <TextBlock Text="侧边栏" Style="{StaticResource GroupTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Logo文本" Style="{StaticResource PropLabel}"/>
                                <TextBox x:Name="TxtSidebarLogo" Grid.Row="0" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="WPF SIDEBAR" TextChanged="OnStyleChanged"/>

                                <TextBlock Grid.Row="1" Text="Logo图标" Style="{StaticResource PropLabel}" Visibility="Collapsed"/>
                                <TextBox x:Name="TxtSidebarLogoIcon" Grid.Row="1" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="🚀" TextChanged="OnStyleChanged" Visibility="Collapsed"/>

                                <TextBlock Grid.Row="2" Text="Logo图片" Style="{StaticResource PropLabel}" Visibility="Collapsed"/>
                                <TextBox x:Name="TxtSidebarLogoImagePath" Grid.Row="2" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="" TextChanged="OnStyleChanged" Visibility="Collapsed"/>

                                <TextBlock Grid.Row="3" Text="使用图片" Style="{StaticResource PropLabel}" Visibility="Collapsed"/>
                                <CheckBox x:Name="ChkSidebarLogoUseImage" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" IsChecked="False" Click="OnGenericStyleChanged" Visibility="Collapsed"/>

                                <TextBlock Grid.Row="4" Text="Logo边距" Style="{StaticResource PropLabel}" Visibility="Collapsed"/>
                                <TextBox x:Name="TxtSidebarLogoMargin" Grid.Row="4" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="10,0,12,0" TextChanged="OnStyleChanged" Visibility="Collapsed"/>

                                <TextBlock Grid.Row="5" Text="行高" Style="{StaticResource PropLabel}"/>
                                <DockPanel Grid.Row="5" Grid.Column="1">
                                    <TextBlock x:Name="LblSidebarItemH" DockPanel.Dock="Right" Text="40" Style="{StaticResource PropLabel}" Width="30" TextAlignment="Right"/>
                                    <Slider x:Name="SliderSidebarItemH" Minimum="20" Maximum="80" Value="40" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                </DockPanel>

                                <TextBlock Grid.Row="6" Text="行间距" Style="{StaticResource PropLabel}"/>
                                <DockPanel Grid.Row="6" Grid.Column="1">
                                    <TextBlock x:Name="LblSidebarItemSpacing" DockPanel.Dock="Right" Text="2" Style="{StaticResource PropLabel}" Width="30" TextAlignment="Right"/>
                                    <Slider x:Name="SliderSidebarItemSpacing" Minimum="0" Maximum="20" Value="2" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                </DockPanel>

                                <TextBlock Grid.Row="7" Text="背景颜色" Style="{StaticResource PropLabel}"/>
                                <DockPanel Grid.Row="7" Grid.Column="1">
                                    <Border x:Name="SwatchSidebarBg" Width="20" Height="20" Margin="0,0,4,0" BorderBrush="Gray" BorderThickness="1" Background="#F0F2F5" MouseLeftButtonDown="Swatch_Click" ToolTip="点击选择颜色"/>
                                    <TextBox x:Name="TxtSidebarBg" Style="{StaticResource PropTextBox}" Text="#F0F2F5" TextChanged="OnStyleChanged"/>
                                </DockPanel>
                            </Grid>
                        </StackPanel>
                        
                        <!-- 顶边栏配置 -->
                        <StackPanel x:Name="GroupTopbarConfig" Visibility="Collapsed">
                            <TextBlock Text="顶边栏" Style="{StaticResource GroupTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Logo文本" Style="{StaticResource PropLabel}"/>
                                <TextBox x:Name="TxtTopbarLogo" Grid.Row="0" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="WPF TOPBAR" TextChanged="OnStyleChanged"/>

                                <TextBlock Grid.Row="1" Text="Logo图标" Style="{StaticResource PropLabel}"/>
                                <TextBox x:Name="TxtTopbarLogoIcon" Grid.Row="1" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="🌟" TextChanged="OnStyleChanged"/>

                                <TextBlock Grid.Row="2" Text="Logo图片" Style="{StaticResource PropLabel}" Visibility="Collapsed"/>
                                <TextBox x:Name="TxtTopbarLogoImagePath" Grid.Row="2" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="" TextChanged="OnStyleChanged" Visibility="Collapsed"/>

                                <TextBlock Grid.Row="3" Text="使用图片" Style="{StaticResource PropLabel}" Visibility="Collapsed"/>
                                <CheckBox x:Name="ChkTopbarLogoUseImage" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" IsChecked="False" Click="OnGenericStyleChanged" Visibility="Collapsed"/>

                                <TextBlock Grid.Row="4" Text="高度" Style="{StaticResource PropLabel}"/>
                                <DockPanel Grid.Row="4" Grid.Column="1">
                                    <TextBlock x:Name="LblTopbarHeight" DockPanel.Dock="Right" Text="60" Style="{StaticResource PropLabel}" Width="30" TextAlignment="Right"/>
                                    <Slider x:Name="SliderTopbarHeight" Minimum="40" Maximum="100" Value="60" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                </DockPanel>

                                <TextBlock Grid.Row="5" Text="项宽度" Style="{StaticResource PropLabel}"/>
                                <DockPanel Grid.Row="5" Grid.Column="1">
                                    <TextBlock x:Name="LblTopbarItemWidth" DockPanel.Dock="Right" Text="100" Style="{StaticResource PropLabel}" Width="30" TextAlignment="Right"/>
                                    <Slider x:Name="SliderTopbarItemWidth" Minimum="60" Maximum="200" Value="100" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnSliderChanged"/>
                                </DockPanel>

                                <TextBlock Grid.Row="6" Text="背景颜色" Style="{StaticResource PropLabel}"/>
                                <DockPanel Grid.Row="6" Grid.Column="1">
                                    <Border x:Name="SwatchTopbarBg" Width="20" Height="20" Margin="0,0,4,0" BorderBrush="Gray" BorderThickness="1" Background="#F0F2F5" MouseLeftButtonDown="Swatch_Click" ToolTip="点击选择颜色"/>
                                    <TextBox x:Name="TxtTopbarBg" Style="{StaticResource PropTextBox}" Text="#F0F2F5" TextChanged="OnStyleChanged"/>
                                </DockPanel>
                            </Grid>
                        </StackPanel>
                        
                        <!-- 图标按钮配置 -->
                        <StackPanel x:Name="GroupIconButtonConfig" Visibility="Collapsed">
                            <TextBlock Text="图标按钮" Style="{StaticResource GroupTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="按钮文本" Style="{StaticResource PropLabel}"/>
                                <TextBox x:Name="TxtIconButtonText" Grid.Row="0" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="图标按钮" TextChanged="OnStyleChanged"/>

                                <TextBlock Grid.Row="1" Text="按钮图标" Style="{StaticResource PropLabel}"/>
                                <TextBox x:Name="TxtIconButtonIconText" Grid.Row="1" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="🎯" TextChanged="OnStyleChanged"/>

                                <TextBlock Grid.Row="2" Text="图标图片" Style="{StaticResource PropLabel}"/>
                                <TextBox x:Name="TxtIconButtonIconPath" Grid.Row="2" Grid.Column="1" Style="{StaticResource PropTextBox}" Text="" TextChanged="OnStyleChanged"/>

                                <TextBlock Grid.Row="3" Text="使用图片" Style="{StaticResource PropLabel}"/>
                                <CheckBox x:Name="ChkIconButtonUseImage" Grid.Row="3" Grid.Column="1" VerticalAlignment="Center" IsChecked="False" Click="OnGenericStyleChanged"/>
                            </Grid>
                        </StackPanel>

                        <Border Height="20"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ========== 右侧：实时预览 ========== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 预览标题栏 -->
            <Border Grid.Row="0" Padding="20,12" Background="#E8E8EE" BorderBrush="#E0E0E6" BorderThickness="0,0,0,1">
                <DockPanel>
                    <TextBlock Text="👁 实时预览" FontSize="16" FontWeight="Bold" Foreground="#333333"/>
                    <TextBlock DockPanel.Dock="Right" Text="在此输入文字测试效果 ↓" FontSize="11"
                               Foreground="#888899" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <!-- 预览区域 -->
            <Border Grid.Row="1" x:Name="PreviewContainer" Padding="40" Background="#F0F0F3" 
                    UseLayoutRounding="True" SnapsToDevicePixels="True"
                    TextOptions.TextFormattingMode="Display">
                <!-- 动态渲染预览控件 -->
            </Border>
        </Grid>
    </Grid>
</Window>
